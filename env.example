# ConvoX Bot - Environment Variables

# Bot Configuration
BOT_NAME=ConvoX Bot
BOT_VERSION=1.0.0
BOT_PREFIX=!
BOT_ADMIN=

# Facebook Configuration
FACEBOOK_APPSTATE_PATH=./appstate.json
FACEBOOK_LISTEN_EVENTS=true
FACEBOOK_LISTEN_TYPING=true
FACEBOOK_SELF_LISTEN=false

# Plugin Configuration
PLUGINS_ENABLED=true
PLUGINS_AUTO_LOAD=true
PLUGINS_HOT_RELOAD=true
PLUGINS_DIR=./plugins

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/bot.log

# Features
FEATURE_MENU=true
FEATURE_PLUGINS=true
FEATURE_COMMANDS=true
FEATURE_AUTO_REPLY=true

# Security
ENABLE_COOLDOWN=true
DEFAULT_COOLDOWN=3
ENABLE_ADMIN_CHECK=true

# Performance
MAX_COMMANDS_PER_MINUTE=60
CACHE_ENABLED=true
CACHE_TTL=300
