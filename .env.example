# ConvoX Bot Environment Configuration
# Danh sách UID admin/owner cách nhau bởi dấu phẩy hoặc khoảng trắng
# Thay đổi các UID này thành UID thực của bạn
ADMIN_UIDS=1000123456789 1000234567891

# Cấu hình bot
BOT_PREFIX=!
BOT_NAME=ConvoX
BOT_VERSION=1.0.0

# Cấu hình Facebook API
FACEBOOK_LOG_LEVEL=silent
FACEBOOK_FORCE_LOGIN=true
FACEBOOK_LISTEN_EVENTS=true
FACEBOOK_LISTEN_TYPING=true
FACEBOOK_SELF_LISTEN=false

# Cấu hình tính năng
ENABLE_MENU=true
ENABLE_PLUGINS=true
ENABLE_COMMANDS=true
ENABLE_AUTO_REPLY=true
ENABLE_AUTO_MARK_READ=true
