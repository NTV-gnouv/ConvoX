{
  "plugins": {
    "enabled": true,
    "autoLoad": true,
    "hotReload": true,
    "pluginDir": "./plugins",
    "defaultPlugins": [
      "menu",
      "help",
      "info",
      "ping",
      "admin",
      "systemadmin"
    ],
    "pluginConfig": {
      "menu": {
        "enabled": true,
        "autoShow": true,
        "showOnStart": true
      },
      "info": {
        "enabled": true,
        "showVersion": true,
        "showUptime": true
      },
      "ping": {
        "enabled": true,
        "showLatency": true
      },
      "help": {
        "enabled": true,
        "showDetailedGuide": true
      }
    }
  }
}
